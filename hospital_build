def add_hospital_bed(bx, by, bz=0):
    bb.createBody('box', halfExtent=[0.45,1.0,0.2],   position=[bx,by,bz+0.2],      color='#AAAAAA', mass=0)
    bb.createBody('box', halfExtent=[0.42,0.9,0.06],  position=[bx,by,bz+0.46],     color='white',   mass=0)
    bb.createBody('box', halfExtent=[0.28,0.15,0.04], position=[bx,by+0.8,bz+0.54], color='#FFFDE7', mass=0)
    bb.createBody('box', halfExtent=[0.45,0.04,0.3],  position=[bx,by+1.0,bz+0.5],  color='#8B6914', mass=0)
    bb.createBody('box', halfExtent=[0.45,0.04,0.2],  position=[bx,by-0.5,bz+0.4],  color='#8B6914', mass=0)
    for lx,ly in [(-0.38,by-0.95),(0.38,by-0.95),(-0.38,by+0.95),(0.38,by+0.95)]:
        bb.createBody('box', halfExtent=[0.03,0.03,0.1], position=[bx+lx,ly,bz+0.1], color='#888888', mass=0)


def add_patient(bx, by, bz=0, skin='#FDBCB4', gown='#E8B4B8'):
    phz = bz + 0.52
    bb.createBody('sphere', radius=0.12,              position=[bx,   by+0.82,phz+0.20], color=skin, mass=0)
    bb.createBody('box', halfExtent=[0.18,0.35,0.12], position=[bx,   by+0.30,phz+0.12], color=gown, mass=0)
    bb.createBody('box', halfExtent=[0.05,0.22,0.06], position=[bx-0.25,by+0.35,phz+0.18], color=skin, mass=0)
    bb.createBody('box', halfExtent=[0.05,0.22,0.06], position=[bx+0.25,by+0.35,phz+0.18], color=skin, mass=0)
    bb.createBody('box', halfExtent=[0.09,0.22,0.08], position=[bx-0.12,by-0.25,phz+0.08], color=gown, mass=0)
    bb.createBody('box', halfExtent=[0.09,0.22,0.08], position=[bx+0.12,by-0.25,phz+0.08], color=gown, mass=0)


def add_arm_robot(rx, ry, rz=0, facing_x=1.0):
    """Franka-style 3-link arm robot with black gripper."""
    fx = facing_x
    # Base
    bb.createBody('box',    halfExtent=[0.14,0.14,0.06], position=[rx,ry,rz+0.06],             color='#37474F', mass=0)
    bb.createBody('sphere', radius=0.10,                 position=[rx,ry,rz+0.18],             color='#ECEFF1', mass=0)
    # Link 1 — vertical column
    bb.createBody('box',    halfExtent=[0.06,0.06,0.18], position=[rx,ry,rz+0.40],             color='#ECEFF1', mass=0)
    bb.createBody('sphere', radius=0.07,                 position=[rx,ry,rz+0.60],             color='#B0BEC5', mass=0)
    # Link 2 — diagonal up-out
    bb.createBody('box',    halfExtent=[0.05,0.05,0.16], position=[rx+fx*0.15,ry,rz+0.72],    color='#ECEFF1', mass=0)
    bb.createBody('sphere', radius=0.06,                 position=[rx+fx*0.28,ry,rz+0.82],    color='#B0BEC5', mass=0)
    # Link 3 — forearm
    bb.createBody('box',    halfExtent=[0.04,0.04,0.14], position=[rx+fx*0.40,ry,rz+0.72],    color='#ECEFF1', mass=0)
    bb.createBody('sphere', radius=0.05,                 position=[rx+fx*0.52,ry,rz+0.66],    color='#B0BEC5', mass=0)
    # Wrist block
    bb.createBody('box',    halfExtent=[0.035,0.035,0.07],position=[rx+fx*0.60,ry,rz+0.60],   color='#37474F', mass=0)
    # Black gripper palm
    bb.createBody('box',    halfExtent=[0.05,0.04,0.05], position=[rx+fx*0.68,ry,rz+0.52],    color='#212121', mass=0)
    # Two gripper fingers
    bb.createBody('box',    halfExtent=[0.012,0.015,0.06],position=[rx+fx*0.72,ry-0.03,rz+0.44], color='#37474F', mass=0)
    bb.createBody('box',    halfExtent=[0.012,0.015,0.06],position=[rx+fx*0.72,ry+0.03,rz+0.44], color='#37474F', mass=0)
    # Blue status light
    bb.createBody('sphere', radius=0.018, position=[rx+fx*0.64,ry,rz+0.68], color='#29B6F6', mass=0)


